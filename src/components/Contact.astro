---
const links = [
  {
    icon: "📧",
    label: "Email",
    value: "saidcarrillo.job@gmail.com",
    href: "mailto:saidcarrillo.job@gmail.com",
    external: false,
  },
  {
    icon: "💼",
    label: "LinkedIn",
    value: "linkedin.com/in/saidCarrillo",
    href: "https://linkedin.com/in/saidCarrillo",
    external: true,
  },
  {
    icon: "🌐",
    label: "Portafolio",
    value: "portafolio.xo.je",
    href: "https://portafolio.xo.je",
    external: true,
  },
];
---
<section id="contacto" class="py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-12" data-fade-left>
      <p class="text-cyan-400 font-mono text-sm mb-2">04.</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Contacto</h2>
      <div class="w-12 h-0.5 bg-cyan-400 mt-3"></div>
    </div>

    <div class="max-w-2xl">
      <p data-fade class="text-gray-400 text-lg leading-relaxed mb-10">
        ¿Tienes un proyecto que necesite
        <span class="text-gray-200 font-medium">rendimiento, seguridad y buenas prácticas</span>?
        Estoy disponible para nuevas oportunidades y colaboraciones.
      </p>

      <div class="flex flex-col gap-3 mb-10">
        {links.map((link, i) => (
          <a
            data-fade
            style={`--delay: ${i * 0.1}s`}
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class="group flex items-center gap-4 p-4 bg-gray-900/60 rounded-xl border border-gray-800 hover:border-cyan-400/40 hover:bg-gray-900 transition-all duration-300"
          >
            <div class="w-11 h-11 bg-gray-800 rounded-lg flex items-center justify-center text-xl shrink-0 group-hover:bg-cyan-400/10 transition-colors duration-300">
              {link.icon}
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-gray-500 text-xs font-mono mb-0.5">{link.label}</p>
              <p class="text-gray-200 group-hover:text-cyan-400 transition-colors duration-200 truncate">
                {link.value}
              </p>
            </div>
            <svg
              class="text-gray-600 group-hover:text-cyan-400 transition-colors duration-200 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>

      <a
        href="mailto:saidcarrillo.job@gmail.com"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cyan-400 text-gray-950 font-bold rounded-xl hover:bg-cyan-300 transition-colors duration-200 text-base"
      >
        Enviar mensaje
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
