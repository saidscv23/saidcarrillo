---
import '../styles/global.css';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CV – Said Carrillo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: #f8fafc;
        color: #1e293b;
        font-size: 14px;
        line-height: 1.6;
      }

      .page {
        max-width: 820px;
        margin: 2rem auto;
        background: #ffffff;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        border-radius: 12px;
        overflow: hidden;
      }

      /* ── Header ── */
      .cv-header {
        background: #0f172a;
        color: #f1f5f9;
        padding: 2.5rem 3rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
        flex-wrap: wrap;
      }

      .cv-header h1 {
        font-size: 2rem;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }

      .cv-header .title {
        color: #22d3ee;
        font-size: 1rem;
        font-weight: 500;
        margin-top: 0.4rem;
      }

      .contact-list {
        list-style: none;
        font-size: 0.82rem;
        color: #94a3b8;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        text-align: right;
      }

      .contact-list a {
        color: #94a3b8;
        text-decoration: none;
      }

      .contact-list a:hover { color: #22d3ee; }

      /* ── Body ── */
      .cv-body {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 0;
      }

      @media (max-width: 640px) {
        .cv-header {
          flex-direction: column;
          padding: 1.75rem 1.5rem;
          gap: 1rem;
        }

        .contact-list { text-align: left; }

        .cv-body {
          grid-template-columns: 1fr;
        }

        .cv-main {
          padding: 1.25rem 1.5rem;
          border-right: none;
          border-bottom: 1px solid #f1f5f9;
        }

        .cv-sidebar {
          padding: 1.25rem 1.5rem;
        }

        .print-bar {
          padding: 0.75rem 1.5rem;
          border-radius: 0;
        }
      }

      .cv-main {
        padding: 2rem 2.5rem;
        border-right: 1px solid #f1f5f9;
      }

      .cv-sidebar {
        padding: 2rem 1.75rem;
        background: #f8fafc;
      }

      /* ── Sections ── */
      .section { margin-bottom: 2rem; }

      .section:last-child { margin-bottom: 0; }

      .section-title {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #22d3ee;
        font-family: 'JetBrains Mono', monospace;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #e2e8f0;
      }

      /* ── Resumen ── */
      .summary {
        color: #475569;
        font-size: 0.88rem;
        line-height: 1.7;
      }

      /* ── Proyectos ── */
      .project { margin-bottom: 1.4rem; }
      .project:last-child { margin-bottom: 0; }

      .project-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.25rem;
      }

      .project-name {
        font-weight: 700;
        font-size: 0.9rem;
        color: #0f172a;
      }

      .project-link {
        font-size: 0.75rem;
        color: #22d3ee;
        text-decoration: none;
        font-family: 'JetBrains Mono', monospace;
      }

      .project-subtitle {
        font-size: 0.75rem;
        color: #64748b;
        margin-bottom: 0.35rem;
        font-style: italic;
      }

      .project-desc {
        font-size: 0.82rem;
        color: #475569;
        line-height: 1.6;
        margin-bottom: 0.5rem;
      }

      .tech-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }

      .tag {
        font-size: 0.7rem;
        font-family: 'JetBrains Mono', monospace;
        background: #f1f5f9;
        color: #0e7490;
        border: 1px solid #e0f2fe;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
      }

      /* ── Skills ── */
      .skill-group { margin-bottom: 1.2rem; }
      .skill-group:last-child { margin-bottom: 0; }

      .skill-category {
        font-size: 0.72rem;
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 0.4rem;
      }

      .skill-items {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }

      .skill-item {
        font-size: 0.72rem;
        background: #e0f2fe;
        color: #0369a1;
        border-radius: 4px;
        padding: 0.15rem 0.45rem;
        font-family: 'JetBrains Mono', monospace;
      }

      /* ── Idiomas / Soft skills ── */
      .list-plain {
        list-style: none;
        font-size: 0.82rem;
        color: #475569;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .list-plain li::before {
        content: "▸ ";
        color: #22d3ee;
        font-size: 0.7rem;
      }

      /* ── Print button ── */
      .print-bar {
        background: #0f172a;
        padding: 0.75rem 3rem;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        border-radius: 0 0 12px 12px;
      }

      .btn-print {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        background: #22d3ee;
        color: #0f172a;
        font-weight: 700;
        font-size: 0.82rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        text-decoration: none;
        transition: background 0.2s;
      }

      .btn-print:hover { background: #67e8f9; }

      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        border: 1px solid #334155;
        color: #94a3b8;
        font-size: 0.82rem;
        border-radius: 8px;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        text-decoration: none;
        transition: border-color 0.2s, color 0.2s;
      }

      .btn-back:hover { border-color: #22d3ee; color: #22d3ee; }

      /* ── Print styles ── */
      @media print {
        body { background: white; font-size: 12px; }

        .page {
          margin: 0;
          box-shadow: none;
          border-radius: 0;
          max-width: 100%;
        }

        .print-bar { display: none; }

        .cv-header { padding: 1.5rem 2rem; }

        .cv-main { padding: 1.25rem 1.75rem; }
        .cv-sidebar { padding: 1.25rem 1.25rem; }

        .project { margin-bottom: 1rem; }
        .section { margin-bottom: 1.25rem; }

        a { color: inherit !important; text-decoration: none !important; }
        .project-link { color: #0e7490 !important; }
      }

      @page {
        margin: 0.5cm;
        size: A4;
      }
    </style>
  </head>
  <body>
    <div class="page">

      <!-- HEADER -->
      <header class="cv-header">
        <div>
          <h1>Said Carrillo</h1>
          <p class="title">Full Stack Developer</p>
        </div>
        <ul class="contact-list">
          <li><a href="mailto:saidcarrillo.job@gmail.com">saidcarrillo.job@gmail.com</a></li>
          <li><a href="https://linkedin.com/in/saidCarrillo" target="_blank">linkedin.com/in/saidCarrillo</a></li>
          <li><a href="https://portafolio.xo.je" target="_blank">portafolio.xo.je</a></li>
        </ul>
      </header>

      <!-- BODY: main + sidebar -->
      <div class="cv-body">

        <!-- MAIN -->
        <div class="cv-main">

          <!-- Resumen -->
          <div class="section">
            <p class="section-title">Perfil Profesional</p>
            <p class="summary">
              Desarrollador Full Stack con experiencia en sistemas web en producción, 
              arquitectura MVC, despliegue en servidores Apache e IIS y proyectos con Laravel. 
              Trabajo enfocado en <strong>rendimiento, seguridad y escalabilidad</strong>, 
              con experiencia en entornos institucionales y proyectos reales para clientes.
            </p>
          </div>

          <!-- Proyectos -->
          <div class="section">
            <p class="section-title">Proyectos Destacados</p>

            <div class="project">
              <div class="project-header">
                <span class="project-name">🛒 NEXASTORE – Plataforma de Ventas</span>
              </div>
              <p class="project-subtitle">Sistema web de gestión comercial en producción</p>
              <p class="project-desc">
                Control de inventario, clientes, ventas y reportes. Sistema completo
                desarrollado con arquitectura MVC y desplegado en entorno real.
              </p>
              <div class="tech-tags">
                <span class="tag">PHP</span>
                <span class="tag">JavaScript</span>
                <span class="tag">MySQL</span>
                <span class="tag">MVC</span>
                <span class="tag">AdminLTE</span>
              </div>
            </div>

            <div class="project">
              <div class="project-header">
                <span class="project-name">🍽️ Sistema Web para Restaurante</span>
              </div>
              <p class="project-subtitle">Gestión de pedidos, cocina y reportes</p>
              <p class="project-desc">
                Interfaz dinámica con actualizaciones en tiempo real mediante AJAX.
                Módulos de cocina, caja y reportes diarios integrados.
              </p>
              <div class="tech-tags">
                <span class="tag">PHP</span>
                <span class="tag">MySQL</span>
                <span class="tag">AJAX</span>
                <span class="tag">jQuery</span>
              </div>
            </div>

            <div class="project">
              <div class="project-header">
                <span class="project-name">🏢 Sistema Empresarial (Laravel)</span>
              </div>
              <p class="project-subtitle">Gestión de clientes, facturación y pagos</p>
              <p class="project-desc">
                Plataforma corporativa desarrollada en Laravel con arquitectura MVC robusta,
                vistas Blade y separación clara de capas de negocio.
              </p>
              <div class="tech-tags">
                <span class="tag">Laravel</span>
                <span class="tag">PHP</span>
                <span class="tag">MySQL</span>
                <span class="tag">Blade</span>
                <span class="tag">MVC</span>
              </div>
            </div>

            <div class="project">
              <div class="project-header">
                <span class="project-name">🌐 Livingood – Constructora</span>
                <a href="https://livingood.xo.je" class="project-link">livingood.xo.je ↗</a>
              </div>
              <p class="project-subtitle">Sitio web corporativo responsive</p>
              <div class="tech-tags">
                <span class="tag">HTML</span>
                <span class="tag">CSS</span>
                <span class="tag">Tailwind</span>
                <span class="tag">JavaScript</span>
              </div>
            </div>

            <div class="project">
              <div class="project-header">
                <span class="project-name">⚡ Electrovolt – Electricista</span>
                <a href="https://electrovolt.xo.je" class="project-link">electrovolt.xo.je ↗</a>
              </div>
              <p class="project-subtitle">Sitio web profesional con catálogo de servicios</p>
              <div class="tech-tags">
                <span class="tag">HTML</span>
                <span class="tag">CSS</span>
                <span class="tag">Tailwind</span>
                <span class="tag">JavaScript</span>
              </div>
            </div>

          </div>
        </div>

        <!-- SIDEBAR -->
        <div class="cv-sidebar">

          <!-- Habilidades técnicas -->
          <div class="section">
            <p class="section-title">Habilidades</p>

            <div class="skill-group">
              <p class="skill-category">Backend</p>
              <div class="skill-items">
                <span class="skill-item">PHP</span>
                <span class="skill-item">Laravel</span>
                <span class="skill-item">MySQL</span>
                <span class="skill-item">MVC</span>
                <span class="skill-item">REST APIs</span>
              </div>
            </div>

            <div class="skill-group">
              <p class="skill-category">Frontend</p>
              <div class="skill-items">
                <span class="skill-item">JavaScript</span>
                <span class="skill-item">jQuery</span>
                <span class="skill-item">AJAX</span>
                <span class="skill-item">HTML5</span>
                <span class="skill-item">CSS3</span>
                <span class="skill-item">Tailwind</span>
              </div>
            </div>

            <div class="skill-group">
              <p class="skill-category">Servidores</p>
              <div class="skill-items">
                <span class="skill-item">Apache</span>
                <span class="skill-item">IIS</span>
                <span class="skill-item">Linux</span>
                <span class="skill-item">cPanel</span>
              </div>
            </div>

            <div class="skill-group">
              <p class="skill-category">Herramientas</p>
              <div class="skill-items">
                <span class="skill-item">Git</span>
                <span class="skill-item">GitHub</span>
                <span class="skill-item">AdminLTE</span>
                <span class="skill-item">Blade</span>
              </div>
            </div>
          </div>

          <!-- Fortalezas -->
          <div class="section">
            <p class="section-title">Fortalezas</p>
            <ul class="list-plain">
              <li>Sistemas en producción</li>
              <li>Seguridad y rendimiento</li>
              <li>Arquitectura escalable</li>
              <li>Entornos institucionales</li>
              <li>Atención al detalle</li>
            </ul>
          </div>

          <!-- Idiomas -->
          <div class="section">
            <p class="section-title">Idiomas</p>
            <ul class="list-plain">
              <li>Español (nativo)</li>
              <li>Inglés (técnico)</li>
            </ul>
          </div>

        </div>
      </div>

      <!-- PRINT BAR -->
      <div class="print-bar">
        <a href="/" class="btn-back">← Volver al portafolio</a>
        <button class="btn-print" onclick="window.print()">
          ⬇ Guardar como PDF
        </button>
      </div>

    </div>
  </body>
</html>
